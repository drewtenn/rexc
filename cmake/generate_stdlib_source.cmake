set(REXC_STDLIB_UNITS "")
foreach(REXC_STDLIB_RX_SOURCE IN LISTS REXC_STDLIB_RX_SOURCES)
	file(READ "${REXC_STDLIB_RX_SOURCE}" REXC_STDLIB_RX_TEXT)
	set(REXC_STDLIB_LAYER "Layer::Std")
	if(REXC_STDLIB_RX_SOURCE MATCHES "/core/")
		set(REXC_STDLIB_LAYER "Layer::Core")
	elseif(REXC_STDLIB_RX_SOURCE MATCHES "/alloc/")
		set(REXC_STDLIB_LAYER "Layer::Alloc")
	elseif(REXC_STDLIB_RX_SOURCE MATCHES "/std/")
		set(REXC_STDLIB_LAYER "Layer::Std")
	endif()
	string(APPEND REXC_STDLIB_UNITS
	       "\t\tSourceUnit{${REXC_STDLIB_LAYER}, \"${REXC_STDLIB_RX_SOURCE}\", R\"REXC_STDLIB(${REXC_STDLIB_RX_TEXT})REXC_STDLIB\"},\n")
endforeach()

configure_file("${REXC_STDLIB_TEMPLATE}" "${REXC_STDLIB_OUTPUT}" @ONLY)
