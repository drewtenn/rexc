{
  "name": "rexy",
  "displayName": "Rexy",
  "description": "Syntax highlighting and editor support for Rexy source files.",
  "version": "0.1.0",
  "publisher": "rexc",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/drewtenn/rexc.git",
    "directory": "tools/vscode-rexy"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rexy",
        "aliases": [
          "Rexy"
        ],
        "extensions": [
          ".rx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rexy",
        "scopeName": "source.rexy",
        "path": "./syntaxes/rexy.tmLanguage.json"
      }
    ]
  }
}
