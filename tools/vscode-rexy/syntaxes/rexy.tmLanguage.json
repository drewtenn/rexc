{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Rexc",
  "scopeName": "source.rexc",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rexc",
          "match": "//.*$"
        }
      ]
    },
    "escape": {
      "patterns": [
        {
          "name": "constant.character.escape.rexc",
          "match": "\\\\[nrt'\"\\\\]"
        },
        {
          "name": "invalid.illegal.escape.rexc",
          "match": "\\\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.rexc",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.rexc"
            },
            "2": {
              "name": "entity.name.function.rexc"
            }
          }
        },
        {
          "name": "meta.function.extern.rexc",
          "match": "\\b(extern)\\s+(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.extern.rexc"
            },
            "2": {
              "name": "keyword.declaration.function.rexc"
            },
            "3": {
              "name": "entity.name.function.rexc"
            }
          }
        },
        {
          "name": "support.function.call.rexc",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.rexc"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rexc",
          "match": "\\b(?:return|if|else|while|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.rexc",
          "match": "\\b(?:let|static)\\b"
        },
        {
          "name": "storage.modifier.rexc",
          "match": "\\b(?:mut|extern)\\b"
        },
        {
          "name": "keyword.operator.cast.rexc",
          "match": "\\b(?:as)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "string.quoted.double.rexc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "include": "#escape"
            }
          ]
        },
        {
          "name": "constant.character.rexc",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "include": "#escape"
            }
          ]
        },
        {
          "name": "constant.language.boolean.rexc",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.numeric.integer.rexc",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rexc",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.rexc",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.rexc",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.rexc",
          "match": "->"
        },
        {
          "name": "keyword.operator.arithmetic.rexc",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.reference.rexc",
          "match": "&"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.rexc",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.rexc",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.rexc",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.rexc",
          "match": "[,;:]"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.rexc",
          "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|bool|char|str)\\b"
        }
      ]
    }
  }
}
